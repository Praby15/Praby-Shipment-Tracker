{
  "manifest_version": 3,
  "name": "ApplyLens",
  "version": "1.0.0",
  "description": "Reads job descriptions and provides a quick fit score.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.naukri.com/*",
    "*://*.internshala.com/*",
    "*://*.indeed.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "ApplyLens",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.naukri.com/*",
        "*://*.internshala.com/*",
        "*://*.indeed.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
